# Database
POSTGRES_USER=grindy
POSTGRES_PASSWORD=grindy
POSTGRES_DB=grindy
DATABASE_URL=postgresql+asyncpg://grindy:grindy@db:5432/grindy

# Telegram
BOT_TOKEN=123456:REPLACE_ME
WEBAPP_URL=https://grindy.ru/app
# Прокси для api.telegram.org (если бот падает с ConnectionRefusedError —
# Telegram заблокирован у провайдера). http/https/socks5.
BOT_PROXY=

# Канал, подписка на который обязательна. Бот должен быть админом канала!
# "" чтобы выключить фичу.
REQUIRE_CHANNEL=@grindywork

# Telegram ID админов через запятую. Эти юзеры:
#   - получают уведомления об автоскрытых вакансиях
#   - имеют доступ к /api/admin/* и админ-секции в WebApp
#   - пропускаются мимо проверки подписки на канал в боте
ADMIN_TG_IDS=731637210

# Модерация
# Скрывать вакансию автоматически после N жалоб от разных пользователей.
REPORT_AUTOHIDE_THRESHOLD=3

# AI moderation + классификатор (Gemini)
# Один ключ — обратная совместимость:
GEMINI_API_KEY=REPLACE_ME
# Несколько ключей через запятую — при квоте/блокировке идёт автоматическая
# ротация на следующий. Берётся первым, GEMINI_API_KEY подмешивается следом.
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-2.5-flash

# Sources
SUPERJOB_API_KEY=
HH_USER_AGENT=Grindy/0.1 (huqtuy@gmail.com)
# Прокси для парсеров (HH/Rabota/Avito). Нужен российский IP, иначе сайты
# режут зарубежные дата-центры (403). Купить можно на proxy6.net /
# proxyline.net (~150-300₽/мес).
# Формат: http://user:pass@host:port  или  socks5://user:pass@host:port
PARSER_PROXY=

# Payments (stub)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Scheduler
RUN_SCHEDULER=true
PARSE_INTERVAL_MIN=60
DIGEST_MORNING="0 9 * * *"
DIGEST_EVENING="0 19 * * *"
# Каждые N минут scheduler шлёт push новых вакансий пользователям с
# notifications_realtime=True.
NOTIFY_INTERVAL_MIN=30

# Observability (Sentry)
# Пусто = выключено. Получи DSN на sentry.io (Free plan).
SENTRY_DSN=
SENTRY_ENV=prod

# CORS
CORS_ORIGINS=http://localhost:5173,https://grindy.ru
