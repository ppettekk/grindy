# Database
POSTGRES_USER=grindy
POSTGRES_PASSWORD=grindy
POSTGRES_DB=grindy
DATABASE_URL=postgresql+asyncpg://grindy:grindy@db:5432/grindy

# Telegram
BOT_TOKEN=123456:REPLACE_ME
WEBAPP_URL=https://grindy.ru/app
# Юзернейм бота без @. Используется для deep-link на WebApp в уведомлениях.
BOT_USERNAME=grindyworkbot
# Short name WebApp из @BotFather (/newapp). Финальная ссылка:
# t.me/<BOT_USERNAME>/<WEBAPP_SHORT_NAME>?startapp=v_<uuid>
WEBAPP_SHORT_NAME=app
# Прокси для api.telegram.org (если бот падает с ConnectionRefusedError —
# Telegram заблокирован у провайдера). http/https/socks5.
BOT_PROXY=

# Канал, подписка на который обязательна. Бот должен быть админом канала!
# "" чтобы выключить фичу.
REQUIRE_CHANNEL=@grindywork

# Telegram ID админов через запятую. Эти юзеры:
#   - получают уведомления об автоскрытых вакансиях
#   - имеют доступ к /api/admin/* и админ-секции в WebApp
#   - пропускаются мимо проверки подписки на канал в боте
ADMIN_TG_IDS=731637210

# Модерация
# Скрывать вакансию автоматически после N жалоб от разных пользователей.
REPORT_AUTOHIDE_THRESHOLD=3

# AI moderation + классификатор аудитории
# Провайдер: deepseek / openai / closerouter / gemini.
# Из EU yeezyhost работают: deepseek, openai, closerouter.
# Gemini требует US-прокси из-за геоблока (либо ходи через closerouter).
LLM_PROVIDER=closerouter
# Ключи провайдера. Один:
LLM_API_KEY=REPLACE_ME
# Несколько через запятую — при квоте/blocked идёт ротация:
LLM_API_KEYS=
# Имя модели. Пусто = дефолт по провайдеру:
#   deepseek    → deepseek-chat
#   openai      → gpt-4o-mini
#   closerouter → anthropic/claude-haiku-4.5  (формат provider/model)
#   gemini      → gemini-2.5-flash
LLM_MODEL=
# Опциональный override base URL для OpenAI-совместимых провайдеров.
# Используй, если хочешь свой self-hosted роутер, vLLM, ollama и т.п.
LLM_BASE_URL=

# Поведение LLM-классификатора (общее для всех провайдеров)
LLM_ENABLED=true
LLM_MAX_CALLS_PER_INGEST=30
LLM_MIN_CONFIDENCE=0.7
LLM_TIMEOUT_SEC=8

# Legacy Gemini-переменные (используются только если LLM_PROVIDER=gemini
# и LLM_API_KEY/KEYS пусты):
GEMINI_API_KEY=
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-2.5-flash

# Sources
SUPERJOB_API_KEY=
HH_USER_AGENT=Grindy/0.1 (huqtuy@gmail.com)
# Avito парсится отдельным контейнером avito-worker (Playwright + Chromium).
AVITO_ENABLED=true
# Как часто парсить Avito (минуты). Avito тяжёлый — реже остальных.
AVITO_INTERVAL_MIN=120
# Прокси для Avito — ОБЯЗАТЕЛЬНО статичный/sticky IP (не ротационный!).
# Ротация рвёт браузерную навигацию. Если пусто — fallback на PARSER_PROXY.
AVITO_PROXY=
# Прокси для парсеров (HH/Rabota/Avito). Нужен российский IP, иначе сайты
# режут зарубежные дата-центры (403). Купить можно на proxy6.net /
# proxyline.net (~150-300₽/мес).
# Формат: http://user:pass@host:port  или  socks5://user:pass@host:port
PARSER_PROXY=

# Payments (stub)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Scheduler
RUN_SCHEDULER=true
PARSE_INTERVAL_MIN=60
DIGEST_MORNING="0 9 * * *"
DIGEST_EVENING="0 19 * * *"
# Каждые N минут scheduler шлёт push новых вакансий пользователям с
# notifications_realtime=True.
NOTIFY_INTERVAL_MIN=30

# Observability (Sentry)
# Пусто = выключено. Получи DSN на sentry.io (Free plan).
SENTRY_DSN=
SENTRY_ENV=prod

# CORS
CORS_ORIGINS=http://localhost:5173,https://grindy.ru
